



{% if product.collections.size > 0 %}
  {% assign current_collection = product.collections.first %}
  {% assign related_products = current_collection.products | where: "id", "!=", product.id | limit: 4 %}

  {% if related_products.size > 0 %}
    <section class="related-products">
      <h2 class="section-title">You may also like</h2>
      <div class="related-products-grid">
        {% for related_product in related_products %}
          <div class="product-card">
            <a href="{{ related_product.url }}" class="product-link">
              <div class="product-image">
                <img src="{{ related_product.featured_image | img_url: 'medium' }}" alt="{{ related_product.title | escape }}">
              </div>
              <div class="product-details">
                <h3 class="product-title">{{ related_product.title }}</h3>
                <p class="product-price">{{ related_product.price | money }}</p>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    </section>
  {% endif %}
{% endif %}
