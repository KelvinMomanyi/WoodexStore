<div class="about-page">
    <!-- Hero Section -->
    <div class="about-hero" style="background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('{{ 'Our-Story2.jpg' | asset_url }}');">
      <div class="hero-overlay">
        <h1 class="hero-title">About Us</h1>
        <p class="hero-subtitle">Discover the essence of luxury and sophistication</p>
      </div>
    </div>
  
    <!-- Our Story Section -->
    { <section class="our-story section-padding">
      <div class="container">
        <div class="mini-container">
            <div class="our-story-text">
              <div>
               <h2 class="section-title">Our Story</h2>
               <p class="section-text">
                 At Fragrance, we believe that fragrance is an art form that transcends time and evokes emotions. Since our inception, we've been dedicated to curating an exquisite collection of luxury perfumes that embody elegance, passion, and individuality.
               </p>
              </div>
            </div>
            <div class="our-story-image">
              <img src="{{ 'Our-Story3.jpg' | asset_url }}" alt="Perfume collection" class="section-image">
            </div>
        </div>    
      </div>
    </section> 


    <!-- Why Choose Us Section -->
    <section class="why-choose-us section-padding">
      <div class="container">
        <h2 class="section-title">Why Choose Us</h2>
        <div class="features-grid">
          <div class="feature-item">
            <ion-icon name="flower-outline" class="feature-icon"></ion-icon>
            <h3>Exquisite Craftsmanship</h3>
            <p>Each fragrance is crafted with precision using the finest ingredients sourced globally.</p>
          </div>
          <div class="feature-item">
            <ion-icon name="earth-outline" class="feature-icon"></ion-icon>
            <h3>Eco-Friendly</h3>
            <p>We prioritize sustainability, ensuring our products are kind to the planet.</p>
          </div>
          <div class="feature-item">
            <ion-icon name="heart-outline" class="feature-icon"></ion-icon>
            <h3>Personalized Service</h3>
            <p>Our team is here to guide you in finding the perfect fragrance for every moment.</p>
          </div>
        </div>
      </div>
    </section>
  
    <!-- Testimonials Section -->
    <section class="testimonials section-padding">
      <div class="container">
        <h2 class="section-title">What Our Customers Say</h2>
        <div class="testimonials-slider">
          <div class="testimonial-item">
            <p>"This is the only store I trust for my signature scent. Their perfumes are divine!"</p>
            <span>- Jane D.</span>
          </div>
          <div class="testimonial-item">
            <p>"Unparalleled service and an amazing collection. I found my forever fragrance here."</p>
            <span>- Michael S.</span>
          </div>
          <div class="testimonial-item">
            <p>"Every scent tells a story. This store is a haven for perfume lovers."</p>
            <span>- Sarah K.</span>
          </div>
        </div>
      </div>
    </section>
  
    <!-- CTA Section -->
    <section class="cta section-padding" style="background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('{{ 'aboutUS-banner.jpg' | asset_url }}');">
      <div class="container">
        <h2>Explore Our Signature Collection</h2>
        <a href="/collections/all" class="btn btn-primary">Shop Now</a>
      </div>
    </section>
  </div>
<style>
    .about-page {
        color: #333;
      }
      
      .about-hero {
        position: relative;
        background-size: cover;
        background-position: center;
        height: 40vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      
      .hero-overlay {
        color: #fff;
        text-align: center;
        padding: 2rem;
      }
      
      .hero-title {
        font-size: 3rem;
        font-weight: bold;
        margin-bottom: 0.5rem;
      }
      
      .hero-subtitle {
        font-size: 1.5rem;
      }
      
      .section-padding {
        padding: 4rem 2rem;
      }
      
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem;
        
      }
      
      .mini-container{
        display:flex;
        width:100%;
        min-height:500px;
        background-color:black;
      }

      .our-story-text {
        display: flex;
        flex-direction: column; /* Aligns the elements vertically */
        justify-content: center; /* Vertically centers the elements */
        align-items: center; /* Horizontally centers the elements */
        height: 100%; /* Makes sure the div takes up the full height of its parent */
        text-align: center; /* Centers text inside the elements */
        background-color:white;
      }



      
      .section-title {
        font-size: 2.5rem;
        margin-bottom: 1.5rem;
        text-align: center;
        color: #111;
      }
      
      .section-text {
        text-align: center;
        margin-bottom: 2rem;
        line-height: 1.8;
      }
      
      .section-image {
        display: block;
        margin: 2rem auto;
        max-width: 50%;
        border-radius: 10px;
      }
      
      .features-grid {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
        justify-content: space-between;
        text-align: center;
      }
      
      .feature-item {
        flex: 1 1 calc(33.333% - 2rem);
        background: #f9f9f9;
        padding: 2rem;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      
      .feature-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        color:var(--granite-gray);
      }
      
      .testimonials-slider {
        display: flex;
        gap: 2rem;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        padding: 2rem 0;
      }
      
      .testimonial-item {
        flex: 0 0 calc(33.333% - 1rem);
        scroll-snap-align: center;
        background: #fff;
        padding: 2rem;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      
      .testimonial-item p {
        font-style: italic;
        margin-bottom: 1rem;
      }
      
      .testimonial-item span {
        font-weight: bold;
      }
      
      .cta {
        background: #ff6f61;
        color: #fff;
        text-align: center;
        padding: 3rem 1rem;
        align-items: center;
      }
      
      .cta h2 {
        font-size: 2rem;
        margin-bottom: 1.5rem;
      }
      
      .btn-primary {
        background: #fff;
        color: #ff6f61;
        padding: 0.8rem 2rem;
        font-size: 1rem;
        font-weight: bold;
        border-radius: 50px;
        text-decoration: none;
        transition: all 0.3s ease;
      }
      
      .btn-primary:hover {
        background: #ff6f61;
        color: #fff;
        border: 2px solid #fff;
      }



  /*About*/
      .about-1 .container {
        display: grid;
        gap: 45px;
      }
      
      .about-1 .wrapper,
      .about-banner { padding-inline-start: 45px; }
      
      .about .section-title { margin-block-end: 35px; }
      
      .about-1 .section-text {
        font-size: var(--fs-6);
        color: var(--white_a70);
        font-weight: var(--fw-300);
        line-height: 1.7;
        margin-block-end: 35px;
      }
      
      .about-img{
        width: 200px;
        height: 200px;
      }
      .about-1 .wrapper::before {
        top: 10px;
        left: 0;
        background-image: url("../images/about-quote.svg");
        background-repeat: no-repeat;
        background-size: contain;
        width: 20px;
        height: 20px;
      }
      
      .about-1 .section-text .em {
        color: var(--white);
        font-weight: var(--fw-400);
        text-decoration: underline;
      }
      
      .about-banner { position: relative; }
      
      .about-1 .shape-1 {
        display: block;
        position: absolute;
        bottom: 10%;
        left: 0;
        z-index: 1;
        width: 100px;
      }
      
      
      
      
      
      @media (max-width: 768px) {

        .about-banner {
          max-width: 500px;
          margin-inline: auto;
        }


        .features-grid {
          flex-direction: column;
        }
      
        .testimonial-item {
          flex: 0 0 90%;
        }

        .mini-container{
          display:flex;
          flex-direction:column;
          justify-content:center;
          align-items:center;

        }
      }

      @media (max-width:992px){
        /**
   * ABOUT
   */

  .about .container {
    grid-template-columns: 0.9fr 1fr;
    align-items: flex-start;
    gap: 80px;
  }

  .about-content { order: 1; }

  .about-banner .shape-2 {
    width: 100%;
    bottom: -20px;
    left: 0;
    animation: moving 8s linear infinite;
  }

  @keyframes moving {
    0%,
    100% { transform: translateY(0); }

    50% { transform: translateY(30px); }
  }

  .about .shape-3 {
    bottom: 0;
    right: 0;
  }
      }

      @media (max-width:1200px){
                /**
          * ABOUT
          */

          .about .container { gap: 120px; }

          .about .shape-1 { width: max-content; }

          .about .section-title { margin-block-end: 70px; }

          .about .wrapper { padding-inline-start: 80px; }

          .about .wrapper::before {
            width: 35px;
            height: 30px;
          }

          .about .section-text {
            --fs-6: 3.2rem;
            margin-block-end: 50px;
          }


      }

      @media(max-width:1400px){
        
        /**
        * ABOUT
        */

        .about { padding-block: 180px 120px; }
      }
      
</style>     
