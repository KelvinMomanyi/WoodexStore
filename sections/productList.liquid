        <div class="card-price">
          {% if product.compare_at_price > product.price %}
            <del class="del">{{ product.compare_at_price | money }}</del>
          {% endif %}
          <data class="price" value="{{ product.price }}">{{ product.price | money }}</data>
        </div>
      </div>
    </div>
