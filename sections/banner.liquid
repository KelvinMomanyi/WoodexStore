
{% comment %} data-section {% endcomment %}
<section class="section banner" aria-label="banner" >
    <div class="container">
        <ul class="banner-list">
            <li>
                <div class="banner-card banner-card-2  has-before hover:shine">
                   <p class="card-subtitle">{{section.settings.subtitle1 }}</p>
                   <h2 class="h2 card-title">{{section.settings.title1 }}</h2>
                   <a {% if section.settings.link %}
                     href="{{ section.settings.link }}"
                     {% else %}
                      role="link" aria-disabled="true"
                      {% endif %}
                     class="btn btn-secondary">{{section.settings.btn_label1}}</a>
                     {% if section.settings.image1 != blank %}
                      <div class="has-bg-image" style="background-image: url('{{ section.settings.image1 | image_url}}');">
                      </div>   
                     {% else %}
                     <div class="has-bg-image" style="background-image: url('{{ 'shoe10.jpg' | asset_url}}');">
                     </div> 
                    {% endif %}
                </div>
            </li>
            <li>
               <div class="banner-card banner-card-1 has-before hover:shine">
                  <h2 class="h2 card-title">{{section.settings.title2 }}</h2>
                  <p class="card-text">
                    {{section.settings.description}}
                  </p>
                  <a {% if section.settings.link %}
                    href="{{ section.settings.link }}"
                    {% else %}
                     role="link" aria-disabled="true"
                     {% endif %}
                    class="btn btn-secondary">{{section.settings.btn_label2}}</a>
                    {% if section.settings.image2 != blank %}
                      <div class="has-bg-image" style="background-image: url('{{ section.settings.image2 | image_url}}');">
                      </div>   
                     {% else %}
                     <div class="has-bg-image" style="background-image: url('{{ 'shoe21.jpg' | asset_url}}');">
                     </div>
                    {% endif %}
                </div>
            </li>
        </ul>
    </div>   
</section>

<style>
  .banner-list{
   display: grid;
   gap:30px;
  }
  
  .banner-card{
    min-height: 420px;
    padding:30px;
  }
  
  .banner-card .card-subtitle{
    color: var(--black);
    font-size: var(--fs-6);
    font-weight: var(--fw-600);
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  
  .banner-card :is(.card-subtitle, .card-title) {text-shadow: 0 0 2px var(--cultured-2);}
  
  .banner-card-1  .card-title {margin-block:10px 30px;}
  
  .banner-card .card-text{
    color:var(--black);
    font-size: var(--fs-7);
    margin-block: 10px 25px;
  }
  
  
  
 
  
  
  
  /*-----------------------------------*\
    #MEDIA QUERIES
  \*-----------------------------------*/
  
  /*
  responsive for larger than 575px screen
  */
  @media screen and (min-width: 575px) {
  
  /*
  BANNER
  */
  .banner-card .card-text { max-width: 30ch;}
  
  
  }
  
  
  /*
  responsive for larger than 768px screen
  */
  @media screen and (min-width: 768px) {
    /*
   BANNER
    */
    
    .banner-list{grid-template-columns: 1fr 0.7fr;}
    
   .banner-card {padding: 50px;}
  
 
    }
  
  
  /*
  responsive for larger than 992px screen
  */
  @media screen and (min-width: 992px) {
     /*
   CUSTOM PROPERTY
    */
  
  
   /*
    BANNER
    */
  
    .banner-list {grid-template-columns: 1fr 0.5fr;}
  
  
  }
  
  /*
  responsive for larger than 1200px screen
  */
  @media screen and (min-width: 1200px) {
   /*
  BANNER
   */
  
   .banner-card-1 .card-title{max-width: 15ch;}
  




  }
</style> 

{% schema %}
{
  "name": "banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image1",
      "label": "Image 1"
    },
    {
      "type": "text",
      "id": "subtitle1",
      "label": "Subtitle 1",
      "default": "NEW COLLECTION"
    },
    {
      "type": "text",
      "id": "title1",
      "label": "Title 1",
      "default": "Discover New Sneaker Collection"
    },
    {
      "type": "text",
      "id": "btn_label1",
      "label": "Button Label",
      "default":"Explore More"
    },
    {
      "type": "url",
      "id": "button_url1",
      "label": "Button URL 1",
      "default": "/collections/all"
    },
    {
      "type": "image_picker",
      "id": "image2",
      "label": "Image 2"
    },
    {
      "type": "text",
      "id": "title2",
      "label": "Title 2",
      "default": "25% off Everything"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "label": "Description",
      "default": "Sneakers in a range of styles and colors for every taste"
    },
    {
      "type": "text",
      "id": "btn_label2",
      "label": "Button Label 2",
      "default":"Shop Now"
    },
    {
      "type": "url",
      "id": "button_url2",
      "label": "Button URL 2",
      "default": "/collections/all"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "banner"
    }
  ]
}
{% endschema %}