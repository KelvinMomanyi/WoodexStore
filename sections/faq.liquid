<div class="faq-container">
    <h1>Frequently Asked Questions</h1>
    
    <div class="faq">
        <input type="checkbox" id="faq1">
        <label for="faq1">What types of perfumes do you sell?</label>
        <div class="faq-content">
            <p>We offer a wide variety of perfumes, including designer fragrances, niche perfumes, and exclusive scents for both men and women.</p>
        </div>
    </div>
    
    <div class="faq">
        <input type="checkbox" id="faq2">
        <label for="faq2">Do you offer international shipping?</label>
        <div class="faq-content">
            <p>Yes! We ship worldwide. Shipping rates and times vary depending on your location.</p>
        </div>
    </div>
    
    <div class="faq">
        <input type="checkbox" id="faq3">
        <label for="faq3">Are your perfumes authentic?</label>
        <div class="faq-content">
            <p>Absolutely! We guarantee 100% authentic perfumes sourced directly from authorized distributors.</p>
        </div>
    </div>
    
    <div class="faq">
        <input type="checkbox" id="faq4">
        <label for="faq4">What is your return policy?</label>
        <div class="faq-content">
            <p>We accept returns within 14 days of purchase, provided the perfume is unopened and in its original packaging.</p>
        </div>
    </div>
</div>

<style>
    .faq-container {
        max-width: 800px;
        margin: 50px auto;
        padding: 20px;
        background: white;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }
    h1 {
        text-align: center;
    }
    .faq {
        border-bottom: 1px solid #ddd;
    }
    .faq input {
        display: none;
    }
    .faq label {
        display: block;
        font-size: 18px;
        font-weight: bold;
        padding: 15px;
        cursor: pointer;
        background: #f1f1f1;
        border-radius: 5px;
        transition: background 0.3s;
    }
    .faq label:hover {
        background: #e0e0e0;
    }
    .faq-content {
        max-height: 0;
        overflow: hidden;
        padding: 0 15px;
        transition: max-height 0.3s ease-out;
    }
    .faq input:checked + .faq-content {
